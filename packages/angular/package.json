{
  "name": "@zentto/datagrid-angular",
  "version": "1.2.2",
  "description": "Angular wrapper for <zentto-grid> web component.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@zentto/datagrid": "*",
    "@zentto/datagrid-core": "*"
  },
  "peerDependencies": {
    "@angular/core": ">=17",
    "@angular/common": ">=17"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zentto-erp/zentto-datagrid"
  },
  "keywords": [
    "datagrid",
    "angular",
    "table",
    "grid",
    "web-component",
    "pivot",
    "zentto"
  ]
}
